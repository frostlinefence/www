---
layout: layouts/base.njk
permalink: /contact/
title: Contact & Free Estimate
description: Contact Frostline Fence for a free estimate. Email us and we'll get back to you within one business day.
---

<section class="page-hero">
  <div class="container">
    <h1 class="page-hero__title">Get a Free Estimate</h1>
    <p class="page-hero__subtitle">Email us and we'll get back to you within one business day.</p>
  </div>
</section>

<section class="section section--light">
  <div class="container container--narrow">

    <div class="contact-cta reveal">
      <div class="contact-cta__icon">✉</div>
      <h2>Ready to Get Started?</h2>
      <p>Send us an email with your project details — property address, fence type, and approximate footage — and we'll put together a free estimate for you.</p>
      <a href="mailto:{{ site.email }}" class="btn btn--primary btn--lg">{{ site.email }}</a>
    </div>

    <div class="contact-meta reveal">
      <div class="contact-meta__item">
        <span class="contact-meta__label">Hours</span>
        <span class="contact-meta__value">{{ site.hours }}</span>
      </div>
      <div class="contact-meta__item">
        <span class="contact-meta__label">Service Area</span>
        <span class="contact-meta__value">Twin Cities Metro</span>
      </div>
    </div>

    <div class="area-grid reveal">
      <h3>Communities We Serve</h3>
      <ul class="area-list area-list--grid">
        {% for area in site.serviceAreas %}
        <li>{{ area }}</li>
        {% endfor %}
      </ul>
    </div>

  </div>
</section>
